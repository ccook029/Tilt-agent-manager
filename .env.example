# Anthropic API Key — required
ANTHROPIC_API_KEY=sk-ant-...

# Google Analytics 4
GA4_PROPERTY_ID=123456789
GOOGLE_APPLICATION_CREDENTIALS_JSON=<base64-encoded service account JSON>

# Resend API Key — for email delivery
RESEND_API_KEY=re_...

# Email config (used by the general orchestrator)
EMAIL_FROM=agents@tiltsports.com
EMAIL_TO=admin@tiltsports.com

# Override analytics report recipients (comma-separated)
REPORT_EMAIL_TO=you@tiltsports.com

# Zoho Inventory + Sheet — required for Stockton (Inventory Agent)
# Create a Self Client at https://api-console.zoho.com/ with scope:
#   ZohoInventory.fullaccess.all,ZohoSheet.dataAPI.READ
ZOHO_CLIENT_ID=1000.XXXX
ZOHO_CLIENT_SECRET=XXXX
ZOHO_REFRESH_TOKEN=1000.XXXX
ZOHO_ORGANIZATION_ID=123456789
# ZOHO_API_DOMAIN=https://www.zohoapis.com        # default, change for EU/IN/AU
# ZOHO_ACCOUNTS_URL=https://accounts.zoho.com      # default, change for EU/IN/AU

# Zoho Books — Accounting team (Sterling Vance CFO + Penny Quill)
# REST fallback uses the SAME ZOHO_* OAuth vars above. Make sure the refresh
# token's scope also includes Books, e.g.:
#   ZohoInventory.fullaccess.all,ZohoSheet.dataAPI.READ,ZohoBooks.fullaccess.all
# (read scopes are enough for v1 propose-only cleanup).
#
# Optional — official Zoho Books MCP server (preferred connection path).
# When set, the Accounting Agent drives Books through the MCP connector.
# Enforce propose-only by enabling READ tools only in your Zoho MCP admin.
# Full setup walkthrough: docs/ZOHO_BOOKS_MCP_SETUP.md
# ZOHO_BOOKS_MCP_URL=https://mcp.zoho.com/books/...
# ZOHO_BOOKS_MCP_TOKEN=your-oauth-token-here

# Zoho Sheet — master inventory spreadsheet (source of truth)
# Resource ID from the sheet URL: https://sheet.zoho.com/sheet/open/<RESOURCE_ID>
ZOHO_SHEET_RESOURCE_ID=vyuaidc72533497c04883a8f75cad1a9dfffb
# ZOHO_SHEET_WORKSHEET_NAME=Sheet1                 # default, change if your tab has a different name

# Email inbox (IMAP, read-only usage) — lets Penny read Interac e-Transfer
# notification emails to identify who bank-feed e-Transfers came from.
# Tilt uses ZOHO MAIL:
#   1. Zoho Mail → Settings → Mail Accounts → IMAP → enable IMAP Access
#   2. accounts.zoho.com → Security → App Passwords → generate one
# Host auto-detects (custom-domain Zoho → imappro.zoho.com, @zoho.com →
# imap.zoho.com, @gmail.com → imap.gmail.com); override with IMAP_HOST if needed.
# NOTE: Zoho Mail IMAP requires a paid Mail plan (not the free webmail-only plan).
INBOX_USER=chris@tilthockey.com
INBOX_APP_PASSWORD=your-app-password-here
# IMAP_HOST=imappro.zoho.com
# IMAP_PORT=993

# Cron secret — Vercel sets this automatically, used to secure cron endpoints
CRON_SECRET=your-secret-here

# Catalog Builder — external deployed tool (tilt-catalog-agent)
# Public base URL of the catalog tool. Safe to commit; the dashboard uses it to
# launch/embed the tool.
NEXT_PUBLIC_CATALOG_URL=https://tilt-catalog-agent.vercel.app/
# Shared secret that gates the catalog tool's endpoints. SERVER-ONLY — note
# there is NO NEXT_PUBLIC_ prefix, so it never ships in the client bundle.
# Must match the value set in the tilt-catalog-agent Vercel project exactly.
# NEVER commit the real value — set it only in Vercel env vars.
CATALOG_ACCESS_KEY=your-catalog-access-key-here

# Claude model override — single switch for every agent (see src/lib/models.ts)
# CLAUDE_MODEL=claude-sonnet-4-6

# ---- Tilt OS staff login (docs/OS_LOGIN_DESIGN.md) ----
# Setting this TURNS ON the login wall (middleware) for the whole app.
# Generate once (32+ random chars) and set the SAME value in every Tilt app
# that verifies OS sessions. Leave unset to keep the app open (pre-launch).
# TILT_OS_SESSION_SECRET=

# tiltweb base URL — enables per-person staff login (proxied to tiltweb's
# /api/os/login, which checks the real admin_users directory).
# TILTWEB_URL=https://www.tilthockey.com

# Transitional shared passcode for before tiltweb's endpoint is deployed:
# staff leave email blank and enter this. Remove once TILTWEB_URL works.
# OS_SHARED_PASSCODE=

# ---- Staff file cabinet (/files) ----
# Created automatically when you add a Blob store to the Vercel project
# (Storage → Create Database → Blob).
# BLOB_READ_WRITE_TOKEN=

# ---- Tilt OS modules (satellite tools federated into HQ) ----
# Shared key satellite tools use to push signals into POST /api/signals
# (Authorization: Bearer <key>). Also generate once and share with each tool.
MODULES_SHARED_KEY=your-modules-shared-key

# Deployed URLs for each module's launch card (server-only; optional keys are
# appended to the launch URL like the Catalog Builder pattern).
# NOTE: the Social Studio was absorbed and now runs natively at /studio/social
# — SOCIAL_APP_URL / SOCIAL_ACCESS_KEY are no longer used.
WEBADMIN_APP_URL=https://tiltweb-admin-url-here/
# WEBADMIN_ACCESS_KEY=
INVENTORY_APP_URL=https://tiltinventory.vercel.app/
# INVENTORY_ACCESS_KEY=

# ---- Social Studio (native module, /studio/social) ----
# All optional: with no database configured the module runs in demo mode and
# serves built-in sample data, so a fresh deploy works with none of these set.

# Database (Neon or Supabase Postgres). Any of DATABASE_URL / POSTGRES_URL /
# POSTGRES_PRISMA_URL etc. work — a Vercel Storage Postgres store auto-injects
# one. Same database the standalone studio used; no data migration needed.
# DATABASE_URL="postgres://user:password@host:5432/tilt?sslmode=require"

# Static visuals: Google Gemini "Nano Banana Pro" (render pipeline)
# GEMINI_API_KEY=

# Asset storage reuses the hub's Vercel Blob store (BLOB_READ_WRITE_TOKEN above).

# Source library: Zoho WorkDrive — OAuth refresh-token flow
# (https://www.zoho.com/workdrive/help/api/). The WorkDrive Self Client is
# usually a DIFFERENT Zoho app from the hub's Books/Inventory client above, so
# the social code reads the ZOHO_WORKDRIVE_-prefixed credentials first and
# falls back to the plain ZOHO_CLIENT_ID / ZOHO_CLIENT_SECRET /
# ZOHO_REFRESH_TOKEN only when the prefixed ones are unset.
# ZOHO_ACCOUNTS_DOMAIN="https://accounts.zoho.com"
# ZOHO_WORKDRIVE_API_BASE="https://www.zohoapis.com/workdrive/api/v1"
# ZOHO_WORKDRIVE_CLIENT_ID=
# ZOHO_WORKDRIVE_CLIENT_SECRET=
# ZOHO_WORKDRIVE_REFRESH_TOKEN=
# Root folder for the TILT HOCKEY SHOOT library
# ZOHO_WORKDRIVE_ROOT_FOLDER_ID="dp2c0b824ab48d67c45cab162b25d38ea9685"

# Claude model overrides for the studio's brain — both default to the hub's
# central CLAUDE_MODEL (src/lib/models.ts) when unset.
# Model used for plan/copy generation
# ANTHROPIC_BRAIN_MODEL=
# Model used for vision tagging of the photo library
# ANTHROPIC_VISION_MODEL=

# Admin actions (the /studio/social/setup buttons)
# Optional second factor: if set, the Initialize/Sync buttons require this
# token. The hub's OS login (TILT_OS_SESSION_SECRET above) is the real gate;
# leave blank and the setup page notes the actions are session-gated only.
# ADMIN_TOKEN=
