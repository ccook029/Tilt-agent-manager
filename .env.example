# Anthropic API Key — required
ANTHROPIC_API_KEY=sk-ant-...

# Google Analytics 4
GA4_PROPERTY_ID=123456789
GOOGLE_APPLICATION_CREDENTIALS_JSON=<base64-encoded service account JSON>

# Resend API Key — for email delivery
RESEND_API_KEY=re_...

# Email config (used by the general orchestrator)
EMAIL_FROM=agents@tiltsports.com
EMAIL_TO=admin@tiltsports.com

# Override analytics report recipients (comma-separated)
REPORT_EMAIL_TO=you@tiltsports.com

# Zoho Inventory + Sheet — required for Stockton (Inventory Agent)
# Create a Self Client at https://api-console.zoho.com/ with scope:
#   ZohoInventory.fullaccess.all,ZohoSheet.dataAPI.READ
ZOHO_CLIENT_ID=1000.XXXX
ZOHO_CLIENT_SECRET=XXXX
ZOHO_REFRESH_TOKEN=1000.XXXX
ZOHO_ORGANIZATION_ID=123456789
# ZOHO_API_DOMAIN=https://www.zohoapis.com        # default, change for EU/IN/AU
# ZOHO_ACCOUNTS_URL=https://accounts.zoho.com      # default, change for EU/IN/AU

# Zoho Sheet — master inventory spreadsheet (source of truth)
# Resource ID from the sheet URL: https://sheet.zoho.com/sheet/open/<RESOURCE_ID>
ZOHO_SHEET_RESOURCE_ID=vyuaidc72533497c04883a8f75cad1a9dfffb
# ZOHO_SHEET_WORKSHEET_NAME=Sheet1                 # default, change if your tab has a different name

# Cron secret — Vercel sets this automatically, used to secure cron endpoints
CRON_SECRET=your-secret-here
