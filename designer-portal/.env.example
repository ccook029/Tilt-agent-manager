# ── Required ────────────────────────────────────────────────────────────────

# Google AI (Gemini) API key — same key the agent manager uses.
# Get one at https://aistudio.google.com
GEMINI_API_KEY=

# The shared passcode your designer types on the login page. Make it long.
PORTAL_PASSCODE=

# ── Recommended ─────────────────────────────────────────────────────────────

# Dedicated secret for signing session cookies. Falls back to PORTAL_PASSCODE
# when unset. Rotate it to force everyone to log in again.
PORTAL_SESSION_SECRET=

# ── Optional overrides ──────────────────────────────────────────────────────

# Image model ("Nano Banana"). Defaults to gemini-3-pro-image-preview.
# GEMINI_IMAGE_MODEL=

# Text model for Chat mode. Defaults to gemini-2.5-flash.
# GEMINI_TEXT_MODEL=

# API endpoint. Defaults to https://generativelanguage.googleapis.com/v1beta
# GEMINI_API_BASE=
