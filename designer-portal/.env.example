# ── Required ────────────────────────────────────────────────────────────────

# Google AI (Gemini) API key — same key the agent manager uses.
# Get one at https://aistudio.google.com
GEMINI_API_KEY=

# Per-user logins: comma- or newline-separated email:password pairs.
# Add a user to grant access; remove one to revoke it (existing sessions
# survive until the cookie expires unless you also rotate the secrets).
#   PORTAL_USERS="gino@example.com:a-long-password, other@tilt.com:another"
PORTAL_USERS=

# ── Optional login fallback ─────────────────────────────────────────────────

# A shared team passcode that works alongside (or instead of) PORTAL_USERS.
# PORTAL_PASSCODE=

# ── Recommended ─────────────────────────────────────────────────────────────

# Dedicated secret for signing session cookies. Falls back to the credential
# vars when unset. Rotate it to force everyone to log in again.
PORTAL_SESSION_SECRET=

# ── Optional overrides ──────────────────────────────────────────────────────

# Image model ("Nano Banana"). Defaults to gemini-3-pro-image-preview.
# GEMINI_IMAGE_MODEL=

# Text model for Chat mode. Defaults to gemini-2.5-flash.
# GEMINI_TEXT_MODEL=

# API endpoint. Defaults to https://generativelanguage.googleapis.com/v1beta
# GEMINI_API_BASE=
